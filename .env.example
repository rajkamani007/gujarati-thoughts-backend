APP_NAME="Gujarati Thoughts API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://gujarati-thoughts-backend-production.up.railway.app

FRONTEND_URL=https://gujarati-thoughts.vercel.app

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=error

# Railway MySQL: link MySQL service to backend, then add ONLY this line:
DB_CONNECTION=mysql

# Railway auto-injects when MySQL is linked (do NOT type these manually):
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQL_URL

# WRONG - do not set these like this:
# DB_PORT=MYSQLPORT
# DB_HOST=MYSQLHOST

SESSION_DRIVER=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
