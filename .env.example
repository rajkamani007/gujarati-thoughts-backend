APP_NAME="Gujarati Thoughts API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://gujarati-thoughts-backend-production.up.railway.app

FRONTEND_URL=https://gujarati-thoughts.vercel.app
SANCTUM_STATEFUL_DOMAINS=gujarati-thoughts.vercel.app,localhost:5173,127.0.0.1:5173

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=error

# Railway: set these in Railway Dashboard → Variables (link MySQL service)
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
